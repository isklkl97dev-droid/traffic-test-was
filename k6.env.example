# 선택 사항 — 이 파일을 k6.env 로 복사하면 npm 프리셋 기본값을 덮어씁니다.
# 사용: cp k6.env.example k6.env  (또는 Windows: copy k6.env.example k6.env)

# 테스트 대상 WAS 호스트 (스킴 포함, 끝 슬래시 없음)
# 예: https://6e77uxt2.awen.3vi.co.kr  /  http://localhost:3000
BASE_URL=

# 초당 요청 수 (constant-arrival-rate). 높을수록 부하·트래픽 증가
RATE=5

# 테스트 지속 시간 (k6 형식: 30s, 1m, 10m, 1h)
DURATION=10m

# BASE_URL 뒤에 붙는 API 경로. bytes 쿼리로 응답 크기(≈ TX 트래픽) 조절
# 1048576 = 1MB, 65536 = 64KB, 524288 = 512KB
TRAFFIC_PATH=/api/traffic?bytes=1048576
